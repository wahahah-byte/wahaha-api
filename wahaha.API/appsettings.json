{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "wahaha.API": "Information"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "wahaha.API": "Information"
      }
    }
  },

  "AllowedHosts": "*",
  "ConnectionStrings": {
    "WahahaByteConnectionString": "set-in-user-secrets",
    "AzureBlobStorage": "set-in-user-secrets"
  },
  "Jwt": {
    "Key": "set-in-user-secrets",
    "Issuer": "https://localhost:7281",
    "Audience": "https://localhost:7281"
  },
  "Points": {
    "DailyLimit": 150,
    "RecurringLimit": 50
  }
}
